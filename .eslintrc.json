{
    "parser": "@typescript-eslint/parser",
    "extends": [
        "plugin:@typescript-eslint/recommended",
        "plugin:prettier/recommended",
        "prettier",
        "plugin:storybook/recommended",
        "plugin:storybook/recommended",
        "plugin:storybook/recommended"
    ],
    "env": {
        "es6": true,
        "node": true,
        "jest": true
    },
    "plugins": [],
    "rules": {
        "@typescript-eslint/no-explicit-any": 0,
        "@typescript-eslint/no-unused-vars": [
            "error",
            {
                "argsIgnorePattern": "^_",
                "varsIgnorePattern": "^_",
                "caughtErrorsIgnorePattern": "^_"
            }
        ],
        "@typescript-eslint/no-inferrable-types": 0,
        "@typescript-eslint/no-non-null-assertion": 0,
        "@typescript-eslint/no-var-requires": 0,
        "@typescript-eslint/ban-ts-ignore": 0,
        "@typescript-eslint/ban-ts-comment": 0,
        "@typescript-eslint/explicit-function-return-type": 0,
        "@typescript-eslint/explicit-module-boundary-types": 0,
        "@typescript-eslint/ban-types": 0,
        "no-restricted-syntax": [
            "error",
            {
                "selector": "JSXAttribute[name.name='css'] Property[key.value=/^@(media|container|supports)/]",
                "message": "App-Studio's `css` prop has no nested selectors/at-rules. For responsive styles use the `media` prop, e.g. media={{ mobile: { ... } }}."
            },
            {
                "selector": "JSXAttribute[name.name='css'] Property[key.value=/^(?!@).*[&:>+~]/]",
                "message": "App-Studio's `css` prop does not support nested selectors like `&:hover` (they are silently ignored). Use an underscore state prop instead, e.g. _hover={{ ... }} / _focus={{ ... }}, or the on={{ hover: { ... } }} map. The `css` prop is only for raw CSS values / variables."
            }
        ],
        "prettier/prettier": [
            "error"
        ]
    }
}
